{
  "name": "web-to-issues",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm build:widget && wrangler dev --port 8787",
    "deploy": "pnpm build:widget && wrangler deploy",
    "build": "tsc",
    "build:widget": "tsx scripts/build-widget.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.widget.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "hono": "^4.12.19",
    "html-to-image": "^1.11.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.10.2",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.1.6",
    "wrangler": "^4.92.0"
  }
}
